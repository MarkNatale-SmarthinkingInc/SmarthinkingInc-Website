{
  "format": "page",
  "id": "blog_post",
  "label": "Blog Post",
  "repeatable": true,
  "status": true,
  "json": {
    "Main": {
      "uid": {
        "type": "UID",
        "config": {
          "label": "UID"
        }
      },
      "title": {
        "type": "Text",
        "config": {
          "label": "title",
          "placeholder": ""
        }
      },
      "featured_image": {
        "type": "Image",
        "config": {
          "label": "featured image",
          "constraint": {},
          "thumbnails": []
        }
      },
      "excerpt": {
        "type": "Text",
        "config": {
          "label": "excerpt",
          "placeholder": ""
        }
      },
      "author_image": {
        "type": "Image",
        "config": {
          "label": "Author Image",
          "constraint": {},
          "thumbnails": []
        }
      },
      "author_name": {
        "type": "Text",
        "config": {
          "label": "Author Name",
          "placeholder": ""
        }
      },
      "introduction": {
        "type": "StructuredText",
        "config": {
          "label": "Introduction",
          "placeholder": "",
          "allowTargetBlank": true,
          "multi": "paragraph,strong,em,hyperlink,list-item,o-list-item"
        }
      },
      "cta_title": {
        "type": "StructuredText",
        "config": {
          "label": "CTA Title (empty = default)",
          "placeholder": "Want to connect with Smarthinking Inc.? Hit reply, and let's talk!",
          "allowTargetBlank": true,
          "single": "paragraph,strong,em"
        }
      },
      "cta_subtitle": {
        "type": "StructuredText",
        "config": {
          "label": "CTA Subtitle (empty = default)",
          "placeholder": "Call us now at",
          "allowTargetBlank": true,
          "multi": "paragraph,strong,em,hyperlink"
        }
      },
      "slices": {
        "type": "Slices",
        "fieldset": "Slice Zone",
        "config": {
          "choices": {
            "quote_block": {
              "type": "SharedSlice"
            },
            "image_block": {
              "type": "SharedSlice"
            },
            "rich_text_block": {
              "type": "SharedSlice"
            }
          }
        }
      }
    },
    "SEO & Metadata": {
      "meta_title": {
        "config": {
          "label": "Meta Title",
          "placeholder": "A title of the page used for social media and search engines"
        },
        "type": "Text"
      },
      "meta_description": {
        "config": {
          "label": "Meta Description",
          "placeholder": "A brief summary of the page"
        },
        "type": "Text"
      },
      "meta_image": {
        "config": {
          "constraint": {
            "height": 1260,
            "width": 2400
          },
          "label": "Meta Image",
          "thumbnails": []
        },
        "type": "Image"
      }
    }
  }
}
