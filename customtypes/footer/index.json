{
  "format": "custom",
  "id": "footer",
  "label": "footer",
  "repeatable": false,
  "status": true,
  "json": {
    "Main": {
      "contact_email": {
        "type": "Text",
        "config": {
          "label": "Contact Email",
          "placeholder": "contact@company.com"
        }
      },
      "contact_phone": {
        "type": "Text",
        "config": {
          "label": "Contact Phone",
          "placeholder": "888.315.4056"
        }
      },
      "contact_address": {
        "type": "StructuredText",
        "config": {
          "label": "Contact Address",
          "placeholder": "Street Address\nCity, State ZIP",
          "allowTargetBlank": false,
          "single": "paragraph,strong,em"
        }
      }
    }
  }
}
